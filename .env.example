# Copier ce fichier en .env et remplir les valeurs

# Ton adresse Gmail (expéditeur)
MAIL_USER=ton.email@gmail.com

# Mot de passe d'application Gmail (pas ton vrai mot de passe)
# Générer sur : https://myaccount.google.com/apppasswords
MAIL_PASS=xxxx xxxx xxxx xxxx

# Adresse de réception (par défaut = MAIL_USER)
MAIL_TO=constantbiosse@gmail.com

# Port du serveur (optionnel, défaut: 3000)
PORT=3000
